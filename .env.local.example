# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
# Get these from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXX

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Convex (Database + Backend) ─────────────────────────────────────────────
# Get this by running: npx convex dev
# (automatically generated after running the dev server for the first time)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ─── Clerk JWT Issuer for Convex Auth ────────────────────────────────────────
# Go to Clerk Dashboard → JWT Templates → Create new → Select "Convex"
# Copy the "Issuer" URL and paste it here
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# ─── Anthropic (AI Insights + Receipt OCR) ───────────────────────────────────
# ⚠️  DO NOT put this in .env.local — it runs server-side only via Convex actions
# Set this in your Convex deployment environment:
#   npx convex env set ANTHROPIC_API_KEY sk-ant-XXXXXXXX
#   OR via the Convex dashboard → Your Project → Environment Variables
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXX   ← NOT here, set in Convex env
